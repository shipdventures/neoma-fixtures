{
  "name": "@neoma/fixtures",
  "version": "0.1.0",
  "description": "Test fixtures for @neoma/* NestJS packages",
  "author": "Shipdventures",
  "repository": {
    "type": "git",
    "url": "https://github.com/shipdventures/neoma-fixtures"
  },
  "bugs": {
    "url": "https://github.com/shipdventures/neoma-fixtures/issues"
  },
  "homepage": "https://github.com/shipdventures/neoma-fixtures#readme",
  "keywords": [
    "nestjs",
    "fixtures",
    "testing",
    "neoma"
  ],
  "private": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "_comment": "This package uses an exports map instead of main+types only because the ./matchers sub-path must be loadable independently via Jest setupFilesAfterEnv without importing the main entry point.",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./matchers": {
      "require": "./dist/matchers/index.js",
      "types": "./dist/matchers/index.d.ts"
    },
    "./docker": {
      "require": "./dist/docker/index.js",
      "types": "./dist/docker/index.d.ts"
    },
    "./setup/mailpit": {
      "require": "./dist/setup/mailpit.js",
      "types": "./dist/setup/mailpit.d.ts"
    },
    "./setup/minio": {
      "require": "./dist/setup/minio.js",
      "types": "./dist/setup/minio.d.ts"
    },
    "./setup/mockserver": {
      "require": "./dist/setup/mockserver.js",
      "types": "./dist/setup/mockserver.d.ts"
    },
    "./teardown/mailpit": {
      "require": "./dist/teardown/mailpit.js",
      "types": "./dist/teardown/mailpit.d.ts"
    },
    "./teardown/minio": {
      "require": "./dist/teardown/minio.js",
      "types": "./dist/teardown/minio.d.ts"
    },
    "./teardown/mockserver": {
      "require": "./dist/teardown/mockserver.js",
      "types": "./dist/teardown/mockserver.d.ts"
    }
  },
  "scripts": {
    "prepublishOnly": "cp ../../README.md ../../LICENSE ."
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "!**/*.json",
    "!**/*.tsbuildinfo"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@nestjs/common": "11.x",
    "@types/jest": ">=29.0.0",
    "jest": ">=29.0.0"
  },
  "dependencies": {
    "@faker-js/faker": "^9.0.0"
  }
}
